{
    "name": "@51eat/sdk",
    "version": "0.0.4",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NexuForma/51eat-sdk-typescript.git"
    },
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./authentication": {
            "import": {
                "types": "./dist/esm/api/resources/authentication/exports.d.mts",
                "default": "./dist/esm/api/resources/authentication/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/authentication/exports.d.ts",
                "default": "./dist/cjs/api/resources/authentication/exports.js"
            },
            "default": "./dist/cjs/api/resources/authentication/exports.js"
        },
        "./broadcasting": {
            "import": {
                "types": "./dist/esm/api/resources/broadcasting/exports.d.mts",
                "default": "./dist/esm/api/resources/broadcasting/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/broadcasting/exports.d.ts",
                "default": "./dist/cjs/api/resources/broadcasting/exports.js"
            },
            "default": "./dist/cjs/api/resources/broadcasting/exports.js"
        },
        "./businessContent": {
            "import": {
                "types": "./dist/esm/api/resources/businessContent/exports.d.mts",
                "default": "./dist/esm/api/resources/businessContent/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/businessContent/exports.d.ts",
                "default": "./dist/cjs/api/resources/businessContent/exports.js"
            },
            "default": "./dist/cjs/api/resources/businessContent/exports.js"
        },
        "./businessProfiles": {
            "import": {
                "types": "./dist/esm/api/resources/businessProfiles/exports.d.mts",
                "default": "./dist/esm/api/resources/businessProfiles/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/businessProfiles/exports.d.ts",
                "default": "./dist/cjs/api/resources/businessProfiles/exports.js"
            },
            "default": "./dist/cjs/api/resources/businessProfiles/exports.js"
        },
        "./customerMessaging": {
            "import": {
                "types": "./dist/esm/api/resources/customerMessaging/exports.d.mts",
                "default": "./dist/esm/api/resources/customerMessaging/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/customerMessaging/exports.d.ts",
                "default": "./dist/cjs/api/resources/customerMessaging/exports.js"
            },
            "default": "./dist/cjs/api/resources/customerMessaging/exports.js"
        },
        "./discovery": {
            "import": {
                "types": "./dist/esm/api/resources/discovery/exports.d.mts",
                "default": "./dist/esm/api/resources/discovery/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/discovery/exports.d.ts",
                "default": "./dist/cjs/api/resources/discovery/exports.js"
            },
            "default": "./dist/cjs/api/resources/discovery/exports.js"
        },
        "./events": {
            "import": {
                "types": "./dist/esm/api/resources/events/exports.d.mts",
                "default": "./dist/esm/api/resources/events/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/events/exports.d.ts",
                "default": "./dist/cjs/api/resources/events/exports.js"
            },
            "default": "./dist/cjs/api/resources/events/exports.js"
        },
        "./myAccount": {
            "import": {
                "types": "./dist/esm/api/resources/myAccount/exports.d.mts",
                "default": "./dist/esm/api/resources/myAccount/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/myAccount/exports.d.ts",
                "default": "./dist/cjs/api/resources/myAccount/exports.js"
            },
            "default": "./dist/cjs/api/resources/myAccount/exports.js"
        },
        "./ticketing": {
            "import": {
                "types": "./dist/esm/api/resources/ticketing/exports.d.mts",
                "default": "./dist/esm/api/resources/ticketing/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/ticketing/exports.d.ts",
                "default": "./dist/cjs/api/resources/ticketing/exports.js"
            },
            "default": "./dist/cjs/api/resources/ticketing/exports.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "biome format --write --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "format:check": "biome format --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint": "biome lint --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint:fix": "biome lint --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check": "biome check --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check:fix": "biome check --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {},
    "devDependencies": {
        "webpack": "^5.105.4",
        "ts-loader": "^9.5.4",
        "vitest": "^4.1.1",
        "msw": "2.11.2",
        "@types/node": "^18.19.70",
        "typescript": "~5.9.3",
        "@biomejs/biome": "2.4.10"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false
}
